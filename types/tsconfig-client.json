{
	"extends": "@epic-web/config/typescript",
	"compilerOptions": {
		"composite": true,
		"allowImportingTsExtensions": true,
		"tsBuildInfoFile": "../node_modules/.tmp/tsconfig.client.tsbuildinfo",
		"baseUrl": "..",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": [],
		"jsx": "react-jsx",
		"jsxImportSource": "remix/component"
	},
	"include": [
		"../client/**/*.d.ts",
		"../client/**/*.ts",
		"../client/**/*.tsx",
		"../shared/**/*.ts"
	]
}
